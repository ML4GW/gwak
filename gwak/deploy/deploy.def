Bootstrap: docker
From: python:3.10.12-slim-bullseye


%files
./deploy /opt/gwak/gwak/deploy
../ml4gw /opt/gwak/ml4gw
../hermes /opt/gwak/hermes

%post
apt-get update
apt-get install -y build-essential
apt-get clean

# install pytest so we can run 
# unit tests during CI inside container
pip install poetry
