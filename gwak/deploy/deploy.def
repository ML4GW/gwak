Bootstrap: docker
From: ghcr.io/astral-sh/uv:0.6.11-python3.11-bookworm-slim

%setup
    mkdir -p ${APPTAINER_ROOTFS}/opt/gwak/gwak/deploy
    rsync -a \
        --exclude '.venv' \
        --exclude '__pycache__' \
        --exclude '.pytest_cache' \
        --exclude '.git' \
        --exclude '*.pyc' \
        $GWAK_DIR/gwak/deploy/ \
        ${APPTAINER_ROOTFS}/opt/gwak/gwak/deploy/

%files
    $GWAK_DIR/gwak/data/data.smk /opt/gwak/gwak/data/data.smk
    $GWAK_DIR/gwak/train/train.smk /opt/gwak/gwak/train/train.smk
    # $GWAK_DIR/gwak/deploy /opt/gwak/gwak/deploy
    $GWAK_DIR/ml4gw /opt/gwak/ml4gw
    $GWAK_DIR/hermes /opt/gwak/hermes

%post
    apt-get update
    apt-get install -y build-essential
    apt-get clean
    # uv tool install snakemake --tool-dir /opt/uv-tools --tool-bin-dir /opt/bin
    export UV_PROJECT_ENVIRONMENT=/opt/env
    cd /opt/gwak/gwak/deploy
    # Set venv dir outside of project for 
    # when binding the repo into the container
    uv export --frozen --all-extras -o requirements.txt
    uv pip sync requirements.txt --system

%environment
    # Append venv dir to PATH so the 
    # environment is active by default
    export PATH="/opt/env/bin:$PATH"
    
    export GWAK_DIR=/opt/gwak

    export GWAK_LOG_DIR=/production/logs
    export GWAK_DATA_DIR=/production/data
    export GWAK_OUTPUT_DIR=/production/output

%runscript
    echo "Environment Check!"
    echo "    GWAK_LOG_DIR: $GWAK_LOG_DIR"
    echo "    GWAK_DATA_DIR: $GWAK_DATA_DIR"
    echo "    GWAK_OUTPUT_DIR: $GWAK_OUTPUT_DIR"